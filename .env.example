# Application Environment Overrides
# Copy this file to '.env' for local development overrides.
# Do not commit your actual '.env' file containing secrets to git.

# App config
APP_ENV=development
APP_NAME=boilerplate-golang

# Server config
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_TIMEOUT_SECONDS=30

# Postgres config
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_DBNAME=boilerplate_db
DATABASE_SSL_MODE=disable

# Redis config
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka config
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=boilerplate-golang-client
KAFKA_GROUP_ID=boilerplate-golang-group
